{
  "name": "@urwesley/workspacelauncher",
  "version": "0.9.2",
  "description": "windows application to launch environments with one click",
  "repository": "https://github.com/ur-wesley/WorkspaceLauncher",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "bun x --bun vite",
    "tauri": "tauri",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "lint": "biome check ./src --fix --formatter-enabled=true --linter-enabled=true",
    "check": "tsc --noEmit",
    "format": "biome format ./src --write",
    "lint:ts": "biome check ./src/**/*.{ts,tsx} --fix",
    "add": "bunx shadcn-solid@latest add",
    "deps": "bunx taze",
    "bump": "bunx bumpp"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@iconify-json/mdi": "^1.2.3",
    "@tauri-apps/cli": "^2.11.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@unocss/vite": "^66.7.0",
    "bumpp": "^11.1.0",
    "lefthook": "^2.1.9",
    "taze": "^19.14.1",
    "typescript": "^6.0.3",
    "unocss": "^66.7.0",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12"
  },
  "dependencies": {
    "@corvu/resizable": "^0.2.5",
    "@iconify/iconify": "^3.1.1",
    "@kobalte/core": "^0.13.11",
    "@melloware/coloris": "^0.25.0",
    "@solid-primitives/keyboard": "^1.3.5",
    "@solid-primitives/timer": "^1.4.4",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.16.1",
    "@stepperize/solid": "^1.0.7",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-autostart": "~2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-sql": "~2.4.0",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@thisbeyond/solid-dnd": "^0.7.5",
    "ansi-to-html": "^0.7.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk-solid": "^1.1.2",
    "neverthrow": "^8.2.0",
    "solid-js": "^1.9.13",
    "somoto": "^0.0.2",
    "tailwind-merge": "^3.6.0",
    "unocss-preset-animations": "^1.3.0",
    "valibot": "^1.4.1"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
